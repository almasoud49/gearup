model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(CUSTOMER)
  isSuspended   Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gearItems     GearItem[]
  rentalOrders  RentalOrder[]
  reviews       Review[]

  
}
